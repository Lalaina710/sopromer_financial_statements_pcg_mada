     Instance pre-configuree BILAN ACTIF
     2 periodes : Exercice courant (offset 0) + Exercice N-1 (offset -1)
     Pour un bilan on s'interesse au solde a une date (bale[X%])
     Periodes type=y (annee) - bale[] retourne le solde au date_to de chaque periode
-->
<odoo noupdate="1">

    <record id="mis_report_instance_bilan_actif" model="mis.report.instance">
        <field name="name">BILAN ACTIF</field>
        <field name="report_id" ref="mis_report_bilan_actif"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="target_move">posted</field>
        <field name="multi_company" eval="False"/>
        <field name="temporary" eval="False"/>
        <field name="widget_show_filters" eval="True"/>
        <field name="display_columns_description" eval="True"/>
    </record>

    <!-- Periode 1 : Exercice courant (NET = solde a date_to year courant) -->
    <record id="mis_report_period_ba_n" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_bilan_actif"/>
        <field name="name">NET Exercice courant</field>
        <field name="sequence">10</field>
        <field name="mode">relative</field>
        <field name="type">y</field>
        <field name="source">actuals</field>
        <field name="offset">0</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

    <!-- Periode 2 : Exercice N-1 (Comparaison = solde a date_to year N-1) -->
    <record id="mis_report_period_ba_n_1" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_bilan_actif"/>
        <field name="name">Comparaison N-1</field>
        <field name="sequence">20</field>
        <field name="mode">relative</field>
        <field name="type">y</field>
        <field name="source">actuals</field>
        <field name="offset">-1</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

</odoo>
