     Instance VARIATION CAPITAUX PROPRES
     3 periodes : N, N-1, N-2 pour visualiser evolution
-->
<odoo noupdate="1">

    <record id="mis_report_instance_variation_cp" model="mis.report.instance">
        <field name="name">VARIATION CAPITAUX PROPRES</field>
        <field name="report_id" ref="mis_report_variation_cp"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="target_move">posted</field>
        <field name="multi_company" eval="False"/>
        <field name="temporary" eval="False"/>
        <field name="widget_show_filters" eval="True"/>
        <field name="display_columns_description" eval="True"/>
    </record>

    <record id="mis_report_period_vcp_n" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_variation_cp"/>
        <field name="name">Solde au 31 decembre N</field>
        <field name="sequence">10</field>
        <field name="mode">relative</field>
        <field name="type">y</field>
        <field name="source">actuals</field>
        <field name="offset">0</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

    <record id="mis_report_period_vcp_n_1" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_variation_cp"/>
        <field name="name">Solde au 31 decembre N-1</field>
        <field name="sequence">20</field>
        <field name="mode">relative</field>
        <field name="type">y</field>
        <field name="source">actuals</field>
        <field name="offset">-1</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

    <record id="mis_report_period_vcp_n_2" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_variation_cp"/>
        <field name="name">Solde au 31 decembre N-2</field>
        <field name="sequence">30</field>
        <field name="mode">relative</field>
        <field name="type">y</field>
        <field name="source">actuals</field>
        <field name="offset">-2</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

</odoo>
