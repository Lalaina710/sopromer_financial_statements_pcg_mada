     Instance pre-configuree CR PAR FONCTION
     2 periodes : Exercice courant (offset 0) + Exercice N-1 (offset -1)
-->
<odoo noupdate="1">

    <record id="mis_report_instance_cr_fonction" model="mis.report.instance">
        <field name="name">COMPTE DE RESULTAT PAR FONCTION</field>
        <field name="report_id" ref="mis_report_cr_par_fonction"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="target_move">posted</field>
        <field name="multi_company" eval="False"/>
        <field name="temporary" eval="False"/>
        <field name="widget_show_filters" eval="True"/>
        <field name="display_columns_description" eval="True"/>
    </record>

    <record id="mis_report_period_crf_n" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_cr_fonction"/>
        <field name="name">Exercice courant</field>
        <field name="sequence">10</field>
        <field name="mode">relative</field>
        <field name="type">y</field>
        <field name="source">actuals</field>
        <field name="offset">0</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

    <record id="mis_report_period_crf_n_1" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_cr_fonction"/>
        <field name="name">Exercice N-1</field>
        <field name="sequence">20</field>
        <field name="mode">relative</field>
        <field name="type">y</field>
        <field name="source">actuals</field>
        <field name="offset">-1</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

</odoo>
