     Instance pre-configuree avec 2 colonnes (exercice N + N-1)
     v18.0.3.0.0 : nom instance sans date (le QWeb ajoute "AU date_to")
                   periodes : Exercice 2026 (data disponible) + 2025 (N-1)
     L'utilisateur peut ajuster dates / periodes via UI MIS Reports
-->
<odoo noupdate="1">

    <record id="mis_report_instance_cr_nature" model="mis.report.instance">
        <field name="name">COMPTE DE RESULTAT PAR NATURE</field>
        <field name="report_id" ref="mis_report_cr_par_nature"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="target_move">posted</field>
        <field name="date_from">2026-01-01</field>
        <field name="date_to">2026-12-31</field>
        <field name="multi_company" eval="False"/>
        <field name="temporary" eval="False"/>
        <field name="widget_show_filters" eval="True"/>
        <field name="display_columns_description" eval="True"/>
    </record>

    <!-- Periode 1 : Exercice 2026 YTD -->
    <record id="mis_report_period_2026" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_cr_nature"/>
        <field name="name">Exercice 2026 YTD</field>
        <field name="sequence">10</field>
        <field name="mode">fix</field>
        <field name="type">date_range</field>
        <field name="source">actuals</field>
        <field name="manual_date_from">2026-01-01</field>
        <field name="manual_date_to">2026-12-31</field>
        <field name="normalize_factor">1</field>
        <field name="offset">-1</field>
        <field name="duration">1</field>
    </record>

    <!-- Periode 2 : Exercice 2025 (N-1) -->
    <record id="mis_report_period_2025" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_cr_nature"/>
        <field name="name">Exercice 2025</field>
        <field name="sequence">20</field>
        <field name="mode">fix</field>
        <field name="type">date_range</field>
        <field name="source">actuals</field>
        <field name="manual_date_from">2025-01-01</field>
        <field name="manual_date_to">2025-12-31</field>
        <field name="normalize_factor">1</field>
        <field name="offset">-1</field>
        <field name="duration">1</field>
    </record>

</odoo>
