     Declaration TVA Madagascar - instance pre-configuree v18.0.10.0.0
     Periodes mensuelles dynamiques :
       - Mois courant (offset 0, type m, duration 1)
       - Mois precedent (offset -1, type m, duration 1)
     pivot_date par defaut = today => offset 0 = mois en cours
-->
<odoo noupdate="1">

    <record id="mis_report_instance_declaration_tva" model="mis.report.instance">
        <field name="name">DECLARATION TVA MADAGASCAR</field>
        <field name="report_id" ref="mis_report_declaration_tva"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="target_move">posted</field>
        <field name="multi_company" eval="False"/>
        <field name="temporary" eval="False"/>
        <field name="widget_show_filters" eval="True"/>
        <field name="display_columns_description" eval="True"/>
    </record>

    <!-- Periode 1 : Mois courant -->
    <record id="mis_report_period_tva_mois_courant" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_declaration_tva"/>
        <field name="name">Mois courant</field>
        <field name="sequence">10</field>
        <field name="mode">relative</field>
        <field name="type">m</field>
        <field name="source">actuals</field>
        <field name="offset">0</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

    <!-- Periode 2 : Mois precedent -->
    <record id="mis_report_period_tva_mois_precedent" model="mis.report.instance.period">
        <field name="report_instance_id" ref="mis_report_instance_declaration_tva"/>
        <field name="name">Mois precedent</field>
        <field name="sequence">20</field>
        <field name="mode">relative</field>
        <field name="type">m</field>
        <field name="source">actuals</field>
        <field name="offset">-1</field>
        <field name="duration">1</field>
        <field name="normalize_factor">1</field>
    </record>

</odoo>
